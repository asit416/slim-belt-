# FitCore Sweat Belt — Environment Variables
# Copy this file to .env and fill in your values

# Server port (default: 3000)
PORT=3000

# Admin secret to access GET /api/orders?secret=...
# Change this to something strong!
ADMIN_SECRET=fitcore2025admin

# CORS origin — set to your actual domain in production
# Example: https://www.fitcoresweatbelt.in
ALLOWED_ORIGIN=*

# (Optional) MongoDB connection string — if upgrading from JSON DB
# MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/fitcore
